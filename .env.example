APP_NAME="WDC Employee Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_DOMAIN=

APP_LOCALE=th
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Asia/Bangkok

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Railway/managed hosts may provide DB_URL, DATABASE_URL, MYSQL_URL, or MYSQL* vars.
DB_URL=
DATABASE_URL=
MYSQL_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wdc
DB_USERNAME=wdc_app
DB_PASSWORD=wdc_local_dev
MYSQLHOST=
MYSQLPORT=
MYSQLDATABASE=
MYSQLUSER=
MYSQLPASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Zoho Mail production example. Put real values in Railway variables or the host
# environment only; do not commit real passwords or app passwords.
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.zoho.com
# MAIL_PORT=587
# MAIL_USERNAME=it-notify@wdc.co.th
# MAIL_PASSWORD=zoho-app-password
# MAIL_SCHEME=tls
# MAIL_ENCRYPTION=tls # legacy fallback; MAIL_SCHEME is preferred
# MAIL_FROM_ADDRESS=it-notify@wdc.co.th
# MAIL_FROM_NAME="${APP_NAME}"
WDC_MAIL_NOTIFICATIONS_ENABLED=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
PAYROLL_URL=https://example.com/payroll
TIME_ATTENDANCE_URL=
